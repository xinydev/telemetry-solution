
{
    "$defs": {
        "Access": {
            "description": "Enumeration of possible values for access",
            "enum": [
                "PMU",
                "ETE"
            ],
            "title": "Access",
            "type": "string"
        },
        "Description": {
            "description": "Text written with a Markdown syntax.\ncan be templated with jinja2 and include a `link` which is used to render a link template define by the generator\n\n.. code-block:: yaml\n\n    This is a description that has link to a parameter [PARAM1]({{link('Parameter', 'PARAM1')}})\n\nThe template of the link can then be defined in when rendering the description:\n\n.. code-block:: python\n\n    my_desc.to_html({'Parameter': '#{{_type}}_{{name}}'})",
            "title": "Description",
            "type": "string"
        },
        "PrivateEvent": {
            "additionalProperties": false,
            "description": "Private Event has only code",
            "properties": {
                "code": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Event register code for counting",
                    "title": "Code"
                }
            },
            "title": "PrivateEvent",
            "type": "object"
        },
        "ProductDefinedAttributes": {
            "additionalProperties": false,
            "description": "Attributes specific to product-defined events.",
            "properties": {
                "debug": {
                    "description": "True if it is a debug event",
                    "title": "Debug",
                    "type": "boolean"
                }
            },
            "required": [
                "debug"
            ],
            "title": "ProductDefinedAttributes",
            "type": "object"
        },
        "DecisionTree": {
            "additionalProperties": false,
            "description": "DecisionTree model dataclass",
            "example": {
                "decision_tree": {
                    "metrics": [
                        {
                            "group": "node_group",
                            "name": "node",
                            "next_items": [
                                "Next_Node"
                            ],
                            "sample_events": [
                                "NODE_EVENT"
                            ]
                        }
                    ],
                    "root_nodes": [
                        "root_node"
                    ]
                }
            },
            "properties": {
                "root_nodes": {
                    "items": {
                        "pattern": "^\\w+$",
                        "type": "string"
                    },
                    "title": "Root Nodes",
                    "type": "array"
                },
                "metrics": {
                    "items": {
                        "$ref": "#/$defs/MetricTree"
                    },
                    "title": "Metrics",
                    "type": "array"
                }
            },
            "required": [
                "root_nodes",
                "metrics"
            ],
            "title": "DecisionTree",
            "type": "object"
        },
        "DocumentMetadata": {
            "additionalProperties": false,
            "description": "Model to validate the DocumentMetadata",
            "example": {
                "document": {
                    "confidential": false,
                    "copyright": "Copyright 2022-2023 Arm Ltd.",
                    "description": "Telemetry Specification for Neoverse Min processor",
                    "license": "Apache-2.0",
                    "quality": "Development",
                    "timestamp": "12 Mar 13:54:40 2024"
                }
            },
            "properties": {
                "timestamp": {
                    "description": "When the document has been generated",
                    "title": "Timestamp",
                    "type": "string"
                },
                "copyright": {
                    "description": "Document copyright",
                    "title": "Copyright",
                    "type": "string"
                },
                "confidential": {
                    "description": "Specify if the document is confidential or not",
                    "title": "Confidential",
                    "type": "boolean"
                },
                "quality": {
                    "description": "Quality level of the document. Available values: Development, Alpha, Beta, Release",
                    "title": "Quality",
                    "type": "string"
                },
                "license": {
                    "description": "Document license",
                    "title": "License",
                    "type": "string"
                },
                "description": {
                    "$ref": "#/$defs/Description",
                    "description": "Document description"
                },
                "revision": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Document revision",
                    "title": "Revision"
                },
                "sha1": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "sha1 or version of the repo who generated the document",
                    "title": "Sha1"
                }
            },
            "required": [
                "timestamp",
                "copyright",
                "confidential",
                "quality",
                "license",
                "description"
            ],
            "title": "DocumentMetadata",
            "type": "object"
        },
        "Event": {
            "additionalProperties": false,
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "architecture_defined": {
                                "const": false
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "architecture_defined_attributes": {
                                "type": "null"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "product_defined": {
                                "const": false
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "product_defined_attributes": {
                                "type": "null"
                            }
                        }
                    }
                },
                {
                    "not": {
                        "properties": {
                            "architecture_defined": {
                                "const": true
                            },
                            "product_defined": {
                                "const": true
                            }
                        }
                    }
                }
            ],
            "description": "Event Model dataclass",
            "example": {
                "events": {
                    "EVENTX": {
                        "accesses": [
                            "PMU"
                        ],
                        "architectural": false,
                        "code": "0x1",
                        "common": false,
                        "description": "EventX description here",
                        "impdef": false,
                        "properties": {
                            "A": "B"
                        },
                        "title": "Example"
                    },
                    "SYS_EVENT": {
                        "accesses": [
                            "PMU"
                        ],
                        "architectural": true,
                        "common": true,
                        "description": "System-level event",
                        "impdef": false,
                        "properties": {
                            "X": "Y"
                        },
                        "system": true,
                        "title": "System Event"
                    }
                }
            },
            "oneOf": [
                {
                    "properties": {
                        "system": {
                            "const": true
                        }
                    },
                    "required": [
                        "system"
                    ]
                },
                {
                    "properties": {
                        "system": {
                            "const": false
                        }
                    },
                    "required": [
                        "system",
                        "code"
                    ]
                },
                {
                    "not": {
                        "required": [
                            "system"
                        ]
                    },
                    "required": [
                        "code"
                    ]
                }
            ],
            "properties": {
                "code": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Event register code for counting",
                    "title": "Code"
                },
                "title": {
                    "description": "Title of the event",
                    "title": "Title",
                    "type": "string"
                },
                "description": {
                    "$ref": "#/$defs/Description",
                    "description": "Description of what is being counted for the event"
                },
                "accesses": {
                    "description": "Access interface - PMU/ETM",
                    "items": {
                        "$ref": "#/$defs/Access"
                    },
                    "title": "Accesses",
                    "type": "array"
                },
                "architecture_defined": {
                    "description": "The event is defined in ARM architecture",
                    "title": "Architecture Defined",
                    "type": "boolean"
                },
                "product_defined": {
                    "description": "The event is product defined",
                    "title": "Product Defined",
                    "type": "boolean"
                },
                "product_defined_attributes": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/ProductDefinedAttributes"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "List of product attributes if the event is product_defined"
                },
                "properties": {
                    "anyOf": [
                        {
                            "patternProperties": {
                                "^\\w+$": {}
                            },
                            "type": "object"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "An expression for addition product specific attributes",
                    "title": "Properties"
                },
                "system": {
                    "default": false,
                    "description": "If system is true, then it is a system event",
                    "title": "System",
                    "type": "boolean"
                }
            },
            "required": [
                "title",
                "description",
                "accesses",
                "architecture_defined",
                "product_defined"
            ],
            "title": "Event",
            "type": "object"
        },
        "GroupCategory": {
            "additionalProperties": false,
            "description": "GroupCategory model dataclass",
            "properties": {
                "title": {
                    "description": "Title of the category",
                    "title": "Title",
                    "type": "string"
                },
                "description": {
                    "$ref": "#/$defs/Description",
                    "description": "Description of the category"
                },
                "metrics": {
                    "anyOf": [
                        {
                            "items": {
                                "pattern": "^\\w+$",
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Group category metrics",
                    "title": "Metrics"
                },
                "events": {
                    "anyOf": [
                        {
                            "items": {
                                "pattern": "^\\w+$",
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Group category events",
                    "title": "Events"
                }
            },
            "required": [
                "title",
                "description"
            ],
            "title": "GroupCategory",
            "type": "object"
        },
        "Methodology": {
            "additionalProperties": false,
            "description": "Methodology model dataclass",
            "example": {
                "topdown_methodology": {
                    "decision_tree": {
                        "metrics": [
                            {
                                "group": "stg_1_metric",
                                "name": "root_node1",
                                "next_items": [
                                    "stg_2_metric"
                                ],
                                "sample_events": [
                                    "NODE1"
                                ]
                            },
                            {
                                "group": "stg_1_metric",
                                "name": "root_node2",
                                "next_items": [
                                    "stg_2_metric2"
                                ],
                                "sample_events": [
                                    "NODE2"
                                ]
                            }
                        ],
                        "root_nodes": [
                            "root_node1",
                            "root_node2"
                        ]
                    },
                    "description": "Topdown Performance Analysis Methodology",
                    "metric_grouping": {
                        "stage_1": [
                            "stg_1_metric"
                        ],
                        "stage_2": [
                            "stg_2_metric",
                            "stg_2_metric2"
                        ]
                    },
                    "title": "Topdown Methodology"
                }
            },
            "properties": {
                "title": {
                    "description": "Methodology title",
                    "title": "Title",
                    "type": "string"
                },
                "description": {
                    "$ref": "#/$defs/Description",
                    "description": "Methodology description"
                },
                "metric_grouping": {
                    "description": "Metric groups used for each stage of the methodology added as lists",
                    "patternProperties": {
                        "^\\w+$": {
                            "items": {
                                "pattern": "^\\w+$",
                                "type": "string"
                            },
                            "type": "array"
                        }
                    },
                    "title": "Metric Grouping",
                    "type": "object"
                },
                "decision_tree": {
                    "$ref": "#/$defs/DecisionTree",
                    "description": "Stage 1 topdown analysis tree with root_nodes and child metrics. Each metric has the following fields: * name: metric name * group: metric groups the metric belong to * next_items: leaves of the node * sample_events: Events for sampling if the bottleneck is detected at this specific metric node"
                }
            },
            "required": [
                "title",
                "description",
                "metric_grouping",
                "decision_tree"
            ],
            "title": "Methodology",
            "type": "object"
        },
        "Metric": {
            "additionalProperties": false,
            "description": "Metric model dataclass",
            "example": {
                "metrics": {
                    "a_metric": {
                        "description": "Metric description here",
                        "events": [],
                        "formula": "NA",
                        "title": "Example",
                        "units": ""
                    }
                }
            },
            "properties": {
                "title": {
                    "description": "Title of the metrics",
                    "title": "Title",
                    "type": "string"
                },
                "formula": {
                    "description": "Formula to compute the metrics",
                    "title": "Formula",
                    "type": "string"
                },
                "description": {
                    "$ref": "#/$defs/Description",
                    "description": "Description of the metrics"
                },
                "units": {
                    "description": "Metrics unit",
                    "title": "Units",
                    "type": "string"
                },
                "events": {
                    "description": "Events needed to calculate the metrics",
                    "items": {
                        "pattern": "^\\w+$",
                        "type": "string"
                    },
                    "title": "Events",
                    "type": "array"
                },
                "sample_events": {
                    "description": "Events for sampling if the bottleneck is detected at this specific metric node",
                    "items": {
                        "pattern": "^\\w+$",
                        "type": "string"
                    },
                    "title": "Sample Events",
                    "type": "array"
                }
            },
            "required": [
                "title",
                "formula",
                "description",
                "units",
                "events",
                "sample_events"
            ],
            "title": "Metric",
            "type": "object"
        },
        "MetricTree": {
            "additionalProperties": false,
            "description": "MetricTree model dataclass",
            "example": {
                "metrics": [
                    {
                        "group": "root_node_group",
                        "name": "root_node",
                        "next_items": [
                            "Next_Root_Node"
                        ],
                        "sample_events": [
                            "ROOT_NODE_EVENT"
                        ]
                    }
                ]
            },
            "properties": {
                "name": {
                    "description": "Metric name",
                    "pattern": "^\\w+$",
                    "title": "Name",
                    "type": "string"
                },
                "group": {
                    "description": "Metric groups the metric belong to",
                    "pattern": "^\\w+$",
                    "title": "Group",
                    "type": "string"
                },
                "next_items": {
                    "description": "leaves of the node",
                    "items": {
                        "pattern": "^\\w+$",
                        "type": "string"
                    },
                    "title": "Next Items",
                    "type": "array"
                },
                "sample_events": {
                    "description": "Events for sampling if the bottleneck is detected at this specific metric node",
                    "items": {
                        "pattern": "^\\w+$",
                        "type": "string"
                    },
                    "title": "Sample Events",
                    "type": "array"
                }
            },
            "required": [
                "name",
                "group",
                "next_items",
                "sample_events"
            ],
            "title": "MetricTree",
            "type": "object"
        },
        "PMUSpecification": {
            "additionalProperties": false,
            "description": "PMUSpecification output dataclass",
            "properties": {
                "$schema": {
                    "title": "$schema",
                    "type": "string"
                  },
                "_type": {
                    "const": "PMU_Specification",
                    "default": "PMU_Specification",
                    "enum": [
                        "PMU_Specification"
                    ],
                    "title": " Type",
                    "type": "string"
                },
                "document": {
                    "$ref": "#/$defs/DocumentMetadata",
                    "description": "Document metadata"
                },
                "product_configuration": {
                    "description": "A collection of configuration parameters",
                    "patternProperties": {
                        "^\\w+$": {}
                    },
                    "title": "Product Configuration",
                    "type": "object"
                },
                "events": {
                    "description": "PMU events supported by the CPU",
                    "patternProperties": {
                        "^\\w+$": {
                            "anyOf": [
                                {
                                    "$ref": "#/$defs/PrivateEvent"
                                },
                                {
                                    "$ref": "#/$defs/Event"
                                }
                            ]
                        }
                    },
                    "title": "Events",
                    "type": "object"
                },
                "metrics": {
                    "description": "Derived metrics supported by the CPU",
                    "patternProperties": {
                        "^\\w+$": {
                            "$ref": "#/$defs/Metric"
                        }
                    },
                    "title": "Metrics",
                    "type": "object"
                },
                "groups": {
                    "additionalProperties": false,
                    "description": "Groups of events and metrics",
                    "properties": {
                        "function": {
                            "description": "Functional groups for events",
                            "patternProperties": {
                                "^\\w+$": {
                                    "$ref": "#/$defs/GroupCategory"
                                }
                            },
                            "type": "object"
                        },
                        "metrics": {
                            "description": "Metrics groups",
                            "patternProperties": {
                                "^\\w+$": {
                                    "$ref": "#/$defs/GroupCategory"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "title": "Groups",
                    "type": "object"
                },
                "methodologies": {
                    "description": "Methodologies stages and decision tree",
                    "patternProperties": {
                        "^\\w+$": {
                            "$ref": "#/$defs/Methodology"
                        }
                    },
                    "title": "Methodologies",
                    "type": "object"
                },
                "instances": {
                    "default": null,
                    "description": "Instances in PMU specification",
                    "patternProperties": {
                        "^\\w+$": {
                            "$ref": "#/$defs/PMUSpecification"
                        }
                    },
                    "title": "Instances",
                    "type": "object"
                }
            },
            "required": [
                "document",
                "product_configuration",
                "events",
                "metrics",
                "groups",
                "methodologies"
            ],
            "title": "PMUSpecification",
            "type": "object"
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/PMUSpecification"
        }
    ]
}
